{
  "name": "portfolio",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration=production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "start:server": "tsx server/main.ts",
    "dev": "concurrently \"ng serve --proxy-config proxy.conf.json\" \"tsx --watch server/main.ts\"",
    "serve:prod": "node dist-server/main.js",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel"
  },
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@angular/animations": "^21.2.8",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.8",
    "@angular/router": "^21.2.0",
    "@vercel/node": "^5.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "nodemailer": "^6.9.16",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/express-rate-limit": "^5.1.3",
    "@types/nodemailer": "^6.4.17",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "tsx": "^4.19.3",
    "typescript": "~5.9.2"
  }
}
