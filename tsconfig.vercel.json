{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": ".vercel/output",
    "rootDir": ".",
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["api/**/*.ts"]
}
